+#ifndef _V_MATH_H
+#define _V_MATH_H
+/* Base headers and utility macros - Included only once */
+    #include <riscv_vector.h>
+
+    /* Recursive concatenation macros 
+     * Used to generate RISC-V Vector intrinsics and ABI-compliant symbols.
+     */
+    #define P(A, B) A##B
+    #define P2(A, B) P(A, B)
+    #define P3(A, B, C) P2(P2(A, B), C)
+    #define P4(A, B, C, D) P2(P3(A, B, C), D)
+    #define P5(A, B, C, D, E) P2(P4(A, B, C, D), E)
+    #define P6(A, B, C, D, E, F) P2(P5(A, B, C, D, E), F)
+#endif
+
+/* Macro Cleanup Section
+ * These must be undefined before every re-inclusion to allow multiple 
+ * LMUL variants (m1, m2, m4, m8) to be generated in the same compilation unit.
+ * IMPORTANT: If you add a new variant-dependent macro, add its #undef here.
+ */
+#undef _M
+#undef _B
+#undef LMUL_ID
+#undef VFLOAT
+#undef VUINT
+#undef VINT
+#undef VBOOL
+#undef VSETVLMAX
+#undef VID
+#undef VREINTERPRET_U
+#undef VREINTERPRET_F
+#undef VREINTERPRET_I
+#undef VFCVT_F
+#undef VMV_X_V_U64
+#undef VFMV_F_S
+#undef SCALAR_FALLBACK
+#undef V_NAME_F1
+#undef V_NAME_F2
+#undef V_NAME_D1
+#undef V_NAME_D2
+
+/* Type and LMUL Configuration
+ * This section defines the scalar types (FTYPE, UTYPE) and vector configurations 
+ * based on the target data type (FLOAT32 or DOUBLE64) and selected LMUL.
+ * Ensure the corresponding BUILD_MX macro is defined before including this file.
+ * calculation: EEW = SEW / LMUL ≤ 64
+ */
+#if defined(FLOAT32)
+    #define _E      32
+    #define FTYPE   float
+    #define ITYPE   int32_t
+    #define UTYPE   uint32_t
+    /* Float32: Supports mf2+ */
+    #if defined(BUILD_MF2)
+        #define _M      mf2
+        #define _B      64
+        #define LMUL_ID f2
+    #elif defined(BUILD_M1)
+        #define _M      m1
+        #define _B      32
+        #define LMUL_ID 1
+    #elif defined(BUILD_M2)
+        #define _M      m2
+        #define _B      16 
+        #define LMUL_ID 2
+    #elif defined(BUILD_M4)
+        #define _M      m4
+        #define _B      8
+        #define LMUL_ID 4
+    #elif defined(BUILD_M8)
+        #define _M      m8
+        #define _B      4
+        #define LMUL_ID 8
+    #else
+        #error "FLOAT32 requires BUILD_MF2/M1/M2/M4/M8"
+    #endif
+#elif defined(DOUBLE64)
+    #define _E      64
+    #define FTYPE   double
+    #define ITYPE   int64_t
+    #define UTYPE   uint64_t
+    /* Double64: Only m1+ */
+    #if defined(BUILD_M1)
+        #define _M      m1
+        #define _B      64
+        #define LMUL_ID 1
+    #elif defined(BUILD_M2)
+        #define _M      m2
+        #define _B      32
+        #define LMUL_ID 2
+    #elif defined(BUILD_M4)
+        #define _M      m4
+        #define _B      16
+        #define LMUL_ID 4
+    #elif defined(BUILD_M8)
+        #define _M      m8
+        #define _B      8
+        #define LMUL_ID 8
+    #else
+        #error "DOUBLE64 requires BUILD_M1/M2/M4/M8 (no fractional LMUL)"
+    #endif
+#endif
+
+/* ABI Naming Convention
+ * Generates symbols following the RISC-V Vector Math Library ABI.
+ * Example: _ZGVr1Nxv_exp (LMUL=1, Vector, Single arg)
+ */
+#define V_NAME_F1(fun)  P5(_ZGVr, LMUL_ID, Nxv_, fun, f)
+#define V_NAME_F2(fun)  P5(_ZGVr, LMUL_ID, Nxvv_, fun, f)
+#define V_NAME_D1(fun)  P4(_ZGVr, LMUL_ID, Nxv_, fun)
+#define V_NAME_D2(fun)  P4(_ZGVr, LMUL_ID, Nxvv_, fun)
+
+/* --- Vector Type Mapping --- */
+#define VBOOL         P3(vbool, _B, _t)
+#define VFLOAT        P4(vfloat, _E, _M, _t)
+#define VUINT         P4(vuint, _E, _M, _t)
+#define VINT          P4(vint, _E, _M, _t)
+
+/* --- Vector Intrinsic Mapping --- */
+#define VSETVLMAX     P3(__riscv_vsetvlmax_e, _E, _M)
+#define VID           P3(__riscv_vid_v_u, _E, _M)
+//vreinterpret
+#define VREINTERPRET_U       P3(__riscv_vreinterpret_u, _E, _M)
+#define VREINTERPRET_I       P3(__riscv_vreinterpret_i, _E, _M)
+#define VREINTERPRET_F       P3(__riscv_vreinterpret_f, _E, _M)
+//convect
+#define VFCVT_F         P3(__riscv_vfcvt_f_x_v_f, _E, _M)
+//vmv
+#define VMV_X_V_U64     P3(__riscv_vmv_v_x_u, _E, _M)             
+//vfmv
+#define VFMV_F_S        P5(__riscv_vfmv_f_s_f, _E, _M, _f, _E)
+
+
+/* SCALAR_FALLBACK
+ * Handles special cases or out-of-range values by invoking the 
+ * standard scalar math function for each active element in a mask.
+ */
+#define SCALAR_FALLBACK(SCALAR_FUN, VX, VY, MASK, VL)         \
+do {                                                          \
+    VBOOL __live = MASK;                                      \
+    VUINT __vseq = VID(VL);                                   \
+    while (__riscv_vcpop(__live, VL) > 0) {                    \
+        UTYPE __pos = __riscv_vfirst(__live, VL);            \
+        FTYPE __elem = VFMV_F_S(__riscv_vslidedown(VX, __pos, VL)); \
+        FTYPE __res = SCALAR_FUN(__elem);                     \
+        VBOOL __bit = __riscv_vmseq(__vseq, __pos, VL);       \
+        VY = __riscv_vfmerge(VY, __res, __bit, VL);           \
+        __live = __riscv_vmxor(__live, __bit, VL);            \
+    }                                                         \
+} while(0)
