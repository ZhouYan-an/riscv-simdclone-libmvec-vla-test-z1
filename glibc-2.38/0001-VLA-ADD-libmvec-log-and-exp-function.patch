+#define LOG_FUNC()      \
+VFLOAT V_NAME_D1(log)(VFLOAT x)    \
+{    \
+    size_t vl = VSETVLMAX();    \
+    VUINT vclass   = __riscv_vfclass(x, vl);    \
+    VUINT special_bits = __riscv_vand(vclass, 0x2BFULL, vl);    \
+    VBOOL special_mask = __riscv_vmsne(special_bits, 0, vl);      \
+    \
+    VUINT ix = VREINTERPRET_U(x);    \
+    VUINT tmp = __riscv_vsub(ix, 0x3fe6900900000000ULL, vl);    \
+    \
+    VUINT i = __riscv_vsrl(tmp, 44, vl);    \
+    i = __riscv_vand(i, 254, vl);    \
+    \
+    VINT ki = VREINTERPRET_I(tmp);    \
+    VINT k = __riscv_vsra(ki, 52, vl);    \
+    VFLOAT kd = VFCVT_F(k, vl);    \
+    \
+    VUINT iz = __riscv_vsub(ix, __riscv_vand(tmp, 0xfffULL << 52, vl), vl);    \
+    VFLOAT z = VREINTERPRET_F(iz);    \
+    \
+    VUINT v_idx_invc = __riscv_vsll(i, 3, vl);    \
+    VUINT v_idx_logc = __riscv_vadd(v_idx_invc, 8, vl);    \
+    \
+    VFLOAT invc = __riscv_vloxei64(log_tab_64f, v_idx_invc, vl);    \
+    VFLOAT logc = __riscv_vloxei64(log_tab_64f, v_idx_logc, vl);    \
+    \
+    VFLOAT r = __riscv_vfadd(__riscv_vfmul(invc, z, vl), -1.0, vl);    \
+    \
+    VFLOAT hi = __riscv_vfadd(logc, r, vl);    \
+    hi = __riscv_vfmadd(kd, log_ln2, hi, vl);    \
+    \
+    VFLOAT r2 = __riscv_vfmul(r, r, vl);    \
+    VFLOAT y = __riscv_vfadd(__riscv_vfmul(r, a3, vl), a2, vl);    \
+    VFLOAT p = __riscv_vfadd(__riscv_vfmul(r, a1, vl), a0, vl);    \
+    y = __riscv_vfmadd(r2, a4, y, vl);    \
+    y = __riscv_vfmadd(r2, y, p, vl);     \
+    \
+    VFLOAT ret = __riscv_vfmadd(r2, y, hi, vl);    \
+    \
+    if (__riscv_vfirst(special_mask, vl) >= 0) {    \
+        SCALAR_FALLBACK(log, x, ret, special_mask, vl);    \
+    }    \
+    return ret;    \
+}
