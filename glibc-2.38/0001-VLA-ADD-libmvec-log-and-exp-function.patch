+
+#define EXP_SCALE 7
+#define EXP_TABLE_SIZE 128
+#define EXP_MASK 0x7F
+
+static const double inv_ln2 = 0x1.71547652b82fep7;
+static const double ln2_hi = 0x1.62e42fefa39efp-8;
+static const double ln2_lo = 0x1.abc9e3b39803f3p-63; 
+static const double shift = 0x1.8p+52; 
+
