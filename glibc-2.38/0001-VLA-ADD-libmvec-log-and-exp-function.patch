diff --git a/sysdeps/riscv/rvd/Makefile b/sysdeps/riscv/rvd/Makefile
new file mode 100644
index 00000000..8c4bc05e
--- /dev/null
+++ b/sysdeps/riscv/rvd/Makefile
@@ -0,0 +1,18 @@
+#rvv-funcs      := exp log
+rvv-funcs      := exp log
+libmvec-support := $(addprefix v_,$(rvv-funcs))
+
+ARCH_FLAGS := -march=rv64gcv_zba_zbb_zbs_zbc_zicond_zcb_zicboz_zicbom_zfa_svinval_zfhmin_zvfh
+OPT_FLAGS  := -O3 -fPIC -flto -ffast-math
+AR         ?= riscv64-unknown-linux-gnu-ar
+
+$(addsuffix .o,$(libmvec-support)): CFLAGS = $(ARCH_FLAGS) $(OPT_FLAGS)
+
+libmvec.so: $(addsuffix .o,$(libmvec-support))
+	$(CC) -shared -o $@ $^
+
+libmvec.a: $(addsuffix .o,$(libmvec-support))
+	$(AR) rcs $@ $^
+
+clean:
+	rm -f *.o libmvec.so libmvec.a
\ No newline at end of file
