+
+#define EXP_FUNC()  \
+VFLOAT V_NAME_D1(exp)(VFLOAT x)  \
+{  \
+    size_t vl = VSETVLMAX();  \
+    VFLOAT x_abs = __riscv_vfabs(x, vl);  \
+    VBOOL mask = __riscv_vmfgt(x_abs, 708, vl);  \
+    VFLOAT vz = __riscv_vfadd(__riscv_vfmul(x, inv_ln2, vl), shift, vl);  \
+    VUINT  vu = VREINTERPRET_U(vz);  \
+    VFLOAT vn = __riscv_vfsub(vz, shift, vl);  \
+  \
+    VFLOAT r = __riscv_vfnmsub(vn, ln2_hi, x, vl);  \
+    r = __riscv_vfnmsub(vn, ln2_lo, r, vl);  \
+  \
+    VFLOAT r2 = __riscv_vfmul(r, r, vl);  \
+    VFLOAT y  = __riscv_vfadd(__riscv_vfmul(r, a1, vl), a0, vl);  \
+    y = __riscv_vfmadd(r2, a2, y, vl);  \
+    y = __riscv_vfmadd(y, r2, r, vl);  \
+  \
+    VUINT idx = __riscv_vsll(__riscv_vand(vu, EXP_MASK, vl), 3, vl);  \
+    VUINT e = __riscv_vsll(vu, 45, vl);  \
+    VUINT tbl = __riscv_vloxei64(exp_tab_64f, idx, vl);      \
+    VFLOAT s  = VREINTERPRET_F(__riscv_vadd(tbl, e, vl));  \
+  \
+    VFLOAT ret = __riscv_vfmadd(s, y, s, vl);  \
+  \
+    if (__riscv_vcpop(mask, vl) > 0) {  \
+        VBOOL n_neg = __riscv_vmflt(vn, 0.0, vl);  \
+        VUINT b = __riscv_vmerge(VMV_X_V_U64(0, vl), 0x6000000000000000ULL, n_neg, vl);  \
+          \
+        VUINT u_s1 = __riscv_vrsub(b, 0x7000000000000000ULL, vl);  \
+        VFLOAT vs1 = VREINTERPRET_F(u_s1);  \
+          \
+        VUINT u_s_raw = VREINTERPRET_U(s);  \
+        VUINT u_s2 = __riscv_vsub(u_s_raw, 0x3010000000000000ULL, vl);  \
+        u_s2 = __riscv_vadd(u_s2, b, vl);  \
+        VFLOAT vs2 = VREINTERPRET_F(u_s2);  \
+          \
+        VFLOAT vr0 = __riscv_vfmadd(vs2, y, vs2, vl);  \
+        vr0 = __riscv_vfmul(vr0, vs1, vl);  \
+          \
+        VFLOAT n_abs = __riscv_vfabs(vn, vl);  \
+        VBOOL p_cmp = __riscv_vmfgt(n_abs, 163840.0, vl);  \
+        VFLOAT vr1 = __riscv_vfmul(vs1, vs1, vl);  \
+          \
+        VFLOAT ret_special = __riscv_vmerge(vr0, vr1, p_cmp, vl);  \
+  \
+        ret = __riscv_vmerge(ret, ret_special, mask, vl);  \
+    }  \
+    return ret;  \
+}
+
+#define BUILD_M1
+#include "v_math.h"
+EXP_FUNC()
+
+#undef BUILD_M1
+#define BUILD_M2
+#include "v_math.h"
+EXP_FUNC()
+
+#undef BUILD_M2
+#define BUILD_M4
+#include "v_math.h"
+EXP_FUNC()
+
+#undef BUILD_M4
+#define BUILD_M8
+#include "v_math.h"
+EXP_FUNC()
